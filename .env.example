# Flux — environment variables
# Copy to .env for local dev (npm run dev:server reads it automatically if
# you use a tool like `dotenv-cli`, or export these in your shell). On
# Vercel, set these under Project Settings → Environment Variables instead.

# ── Storage backend ──────────────────────────────────────────────────────
# Leave both unset to use the local JSON-file store (server/db.js) — the
# default for self-hosting / Electron. Set BOTH to switch to Supabase
# (server/db-supabase.js) — required for Vercel, since serverless functions
# have no persistent local filesystem.
SUPABASE_URL=
# Use the SERVICE ROLE key, not the anon/public key — this runs server-side
# only and needs to bypass Row Level Security. Never expose this to a client.
SUPABASE_SERVICE_ROLE_KEY=

# Only used by the local JSON-file store. Defaults to the same location the
# Electron app uses, so the web server and desktop app share data automatically.
# DB_PATH=/path/to/flux-data.json

# ── Encryption ───────────────────────────────────────────────────────────
# Required when using Supabase (there's no local file to derive/persist a
# key against). Optional but recommended for the local file store too.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────
# Registration is always open for the very first account (there's no admin
# yet to grant access otherwise). After that, set this to allow further
# signups — otherwise only the admin can add more accounts via a future
# invite flow. Can also be toggled at runtime from Admin Settings.
ALLOW_SIGNUP=false

# Comma-separated list of origins allowed to make cross-origin requests to
# this API. Leave unset for same-origin-only (the frontend and API served
# from the same domain — the normal Vercel setup). Needed if you serve the
# frontend from a different domain than the API, or for Electron's "connect
# to an external server" remote mode.
# CORS_ORIGIN=https://flux.example.com

# ── AI features (optional) ───────────────────────────────────────────────
# Ollama running somewhere reachable over HTTP. On Vercel, this can't be
# "localhost" (nothing persistent runs there) — point it at Ollama running
# on your own machine/VPS, reachable over the internet or a private network
# (e.g. Tailscale). Self-starting Ollama (the "auto-start" setting) only
# works on a traditional always-on host, not on Vercel/serverless.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=nomic-embed-text

# ── Misc ──────────────────────────────────────────────────────────────────
PORT=3000
